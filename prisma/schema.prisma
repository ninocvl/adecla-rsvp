generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COMPANY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AffiliationType {
  CONSTRUCTOR
  PROVEEDOR
  DESARROLLADOR
}

enum RegistrationStatus {
  PROFORMA_GENERADA
  PENDIENTE_PAGO
  EN_REVISION
  CONFIRMADA
  CANCELADA
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String
  role          Role            @default(COMPANY)
  company       Company?
  statusChanges StatusHistory[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Company {
  id               String          @id @default(cuid())
  // Opcional a propósito: hoy las empresas se inscriben con un formulario,
  // sin crear cuenta (decisión de producto para no complicar el registro
  // mientras el volumen es bajo). El vínculo a User queda listo para
  // activarse más adelante sin tener que rediseñar el modelo.
  userId           String?         @unique
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalName        String
  rnc              String          @unique
  contactName      String
  email            String
  phone            String
  affiliationType  AffiliationType
  // Si se registró seleccionando su empresa del listado de socios de ADECLA,
  // queda vinculada aquí — así el admin ve de un vistazo si es la misma
  // empresa que ya conocía o una nueva que se está registrando por primera vez.
  affiliateId      String?
  affiliate        Affiliate?      @relation(fields: [affiliateId], references: [id])
  // Marcada por empresas que dijeron no ser afiliadas pero quieren serlo;
  // Katherin las contacta para el proceso de afiliación fuera del sistema.
  wantsToAffiliate Boolean         @default(false)
  registrations    Registration[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

// Copia de solo lectura del listado de socios de ADECLA (importado del
// Excel que maneja Katherin). No es una cuenta ni tiene login: solo sirve
// para que el formulario de registro autocomplete datos conocidos y evite
// que la misma empresa quede duplicada con nombres distintos.
model Affiliate {
  id              String           @id @default(cuid())
  sourceId        String?
  name            String
  affiliationType AffiliationType?
  contactName     String?
  phone           String?
  email           String?
  status          String?
  companies       Company[]
  createdAt       DateTime         @default(now())
}

model Event {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  description    String?
  imageUrl       String?
  codePrefix     String         @unique
  codeSeq        Int            @default(0)
  status         EventStatus    @default(DRAFT)
  playersPerTeam Int            @default(2)
  minPlayers     Int            @default(1)
  dates          EventDate[]
  prices         EventPrice[]
  registrations  Registration[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model EventDate {
  id            String         @id @default(cuid())
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date          DateTime
  label         String
  venue         String
  imageUrl      String?
  capacity      Int            @default(150)
  reservedCount Int            @default(0)
  isActive      Boolean        @default(true)
  registrations Registration[]

  @@unique([eventId, date])
}

model EventPrice {
  id          String          @id @default(cuid())
  eventId     String
  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  affiliation AffiliationType
  amountUsd   Decimal?        @db.Decimal(10, 2)
  isEnabled   Boolean         @default(true)

  @@unique([eventId, affiliation])
}

model Registration {
  id           String             @id @default(cuid())
  code         String             @unique
  companyId    String
  company      Company            @relation(fields: [companyId], references: [id])
  eventId      String
  event        Event              @relation(fields: [eventId], references: [id])
  eventDateId  String
  eventDate    EventDate          @relation(fields: [eventDateId], references: [id])
  affiliation  AffiliationType
  status       RegistrationStatus @default(PROFORMA_GENERADA)
  quantity     Int
  unitPriceUsd Decimal            @db.Decimal(10, 2)
  totalUsd     Decimal            @db.Decimal(10, 2)
  exchangeRate Decimal            @db.Decimal(10, 2)
  totalDopRef  Decimal            @db.Decimal(12, 2)
  participants Participant[]
  proforma     Proforma?
  history      StatusHistory[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([companyId])
  @@index([eventDateId, status])
}

model Participant {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fullName       String
  email          String?
  phone          String?
  position       Int          @default(1)
}

model Proforma {
  id             String       @id @default(cuid())
  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  number         String       @unique
  issuedAt       DateTime     @default(now())
  snapshot       Json
}

model StatusHistory {
  id             String              @id @default(cuid())
  registrationId String
  registration   Registration        @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fromStatus     RegistrationStatus?
  toStatus       RegistrationStatus
  changedById    String?
  changedBy      User?               @relation(fields: [changedById], references: [id])
  note           String?
  createdAt      DateTime            @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
