generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COMPANY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AffiliationType {
  CONSTRUCTOR
  PROVEEDOR
  DESARROLLADOR
}

enum RegistrationStatus {
  PROFORMA_GENERADA
  PENDIENTE_PAGO
  EN_REVISION
  CONFIRMADA
  CANCELADA
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String
  role          Role            @default(COMPANY)
  company       Company?
  statusChanges StatusHistory[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Company {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalName     String
  rnc           String         @unique
  contactName   String
  email         String
  phone         String
  registrations Registration[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Event {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  description    String?
  imageUrl       String?
  codePrefix     String         @unique
  codeSeq        Int            @default(0)
  status         EventStatus    @default(DRAFT)
  playersPerTeam Int            @default(2)
  minPlayers     Int            @default(1)
  dates          EventDate[]
  prices         EventPrice[]
  registrations  Registration[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model EventDate {
  id            String         @id @default(cuid())
  eventId       String
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  date          DateTime
  label         String
  venue         String
  capacity      Int            @default(150)
  reservedCount Int            @default(0)
  isActive      Boolean        @default(true)
  registrations Registration[]

  @@unique([eventId, date])
}

model EventPrice {
  id          String          @id @default(cuid())
  eventId     String
  event       Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  affiliation AffiliationType
  amountUsd   Decimal?        @db.Decimal(10, 2)
  isEnabled   Boolean         @default(true)

  @@unique([eventId, affiliation])
}

model Registration {
  id           String             @id @default(cuid())
  code         String             @unique
  companyId    String
  company      Company            @relation(fields: [companyId], references: [id])
  eventId      String
  event        Event              @relation(fields: [eventId], references: [id])
  eventDateId  String
  eventDate    EventDate          @relation(fields: [eventDateId], references: [id])
  affiliation  AffiliationType
  status       RegistrationStatus @default(PROFORMA_GENERADA)
  quantity     Int
  unitPriceUsd Decimal            @db.Decimal(10, 2)
  totalUsd     Decimal            @db.Decimal(10, 2)
  exchangeRate Decimal            @db.Decimal(10, 2)
  totalDopRef  Decimal            @db.Decimal(12, 2)
  participants Participant[]
  proforma     Proforma?
  history      StatusHistory[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([companyId])
  @@index([eventDateId, status])
}

model Participant {
  id             String       @id @default(cuid())
  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fullName       String
  email          String?
  phone          String?
  position       Int          @default(1)
}

model Proforma {
  id             String       @id @default(cuid())
  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  number         String       @unique
  issuedAt       DateTime     @default(now())
  snapshot       Json
}

model StatusHistory {
  id             String              @id @default(cuid())
  registrationId String
  registration   Registration        @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fromStatus     RegistrationStatus?
  toStatus       RegistrationStatus
  changedById    String?
  changedBy      User?               @relation(fields: [changedById], references: [id])
  note           String?
  createdAt      DateTime            @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
